{
  "name": "pashto-calendar",
  "version": "1.0.0",
  "description": "Pashto Calendar Laravel package with events, holidays, dark mode and offline support",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "tailwindcss -i ./resources/css/app.css -o ./public/css/pashto-calendar.css --minify",
    "build:js": "esbuild resources/js/app.js --bundle --minify --outfile=public/js/pashto-calendar.js"
  },
  "keywords": [
    "laravel",
    "calendar",
    "pashto",
    "jalali",
    "alpinejs",
    "tailwind"
  ],
  "author": "Abdul Qadir Nasrat",
  "license": "MIT",
  "dependencies": {
    "alpinejs": "^3.15.12",
    "axios": "^1.18.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.0",
    "esbuild": "^0.23.0"
  }
}
